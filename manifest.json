{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.0",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "content_security_policy": {
    "sandbox": "sandbox allow-scripts; script-src 'self' 'unsafe-eval'; worker-src 'self' blob:"
  },
  "sandbox": {
    "pages": ["src/overlay/assets/sandbox.html"]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "src/overlay/*",
        "src/overlay/assets/*",
        "src/overlay/assets/models/*"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
